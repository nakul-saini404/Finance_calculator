{
    "rewrites": [
        {
            "source": "/finance-calculators/assets/(.*)",
            "destination": "/finance-calculators/assets/$1"
        },
        {
            "source": "/finance-calculators/(.*)",
            "destination": "/index.html"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}